# Core app
APP_NAME=EQIP
APP_ENV=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Database
# SQLite default for local V1
DATABASE_URL=sqlite:///eqip.db
SQLITE_WAL_MODE=true

# Optional market-data provider defaults
YFINANCE_DEFAULT_PERIOD=1y
YFINANCE_DEFAULT_INTERVAL=1d

# Optional dependency feature flags (graceful fallback still required)
ENABLE_QUANTLIB=false
ENABLE_ZIPLINE=false
ENABLE_SKFOLIO=false
ENABLE_ARCH=false

# Execution controls
ENABLE_LIVE_TRADING=false
REQUIRE_LIVE_TRADING_CONFIRMATION=true
MAX_ORDER_NOTIONAL=10000
MAX_GROSS_EXPOSURE=100000

# Upload controls
MAX_UPLOAD_MB=25
ALLOW_TRUSTED_PICKLE=false

# Randomness / reproducibility
GLOBAL_RANDOM_SEED=42

# Reporting/exports
EXPORT_DIR=./exports

